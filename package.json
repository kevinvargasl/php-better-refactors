{
  "name": "php-better-refactors",
  "displayName": "PHP Better Refactors",
  "description": "PSR-4-aware PHP refactoring: automatic class/file/namespace, properties and methods renaming and cross-project reference updates",
  "version": "0.1.2",
  "publisher": "kevinvargasl",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinvargasl/php-better-refactors"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/composer.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "phpBetterRefactors.reindex",
        "title": "PHP Better Refactors: Rebuild Index"
      }
    ],
    "configuration": {
      "title": "PHP Better Refactors",
      "properties": {
        "phpBetterRefactors.enableAutoRename": {
          "type": "boolean",
          "default": true,
          "description": "Automatically rename class when file is renamed"
        },
        "phpBetterRefactors.enableAutoNamespace": {
          "type": "boolean",
          "default": true,
          "description": "Automatically update namespace when file is moved"
        },
        "phpBetterRefactors.excludePatterns": {
          "type": "array",
          "default": [
            "**/vendor/**",
            "**/node_modules/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "Patterns for files/folders to exclude from reference scanning"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "lint": "eslint src",
    "test": "node ./out/test/runTests.js",
    "test:unit": "mocha ./out/test/unit/**/*.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.19.11",
    "eslint": "^10.0.3",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "php-parser": "3.1.5"
  }
}
